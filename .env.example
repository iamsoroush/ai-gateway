OPENAI_API_KEY=
GEMINI_API_KEY=
LOG_LEVEL=INFO
# Used when a request omits "model". DEFAULT_AUDIO_MODEL is used when the request
# contains audio; DEFAULT_MODEL is used otherwise.
DEFAULT_MODEL=gpt-5.4-nano
DEFAULT_AUDIO_MODEL=gemini-2.5-flash
# Durable store for the requests table (one row per request — usage is computed from
# it): a Postgres DSN. Set it to persist across restarts and share across workers; leave
# blank for the in-memory store (resets on restart). `docker compose up` runs a Postgres
# service and injects DATABASE_URL automatically — you only need this for a non-Docker run.
# DATABASE_URL=postgresql://ai_gateway:ai_gateway@localhost:5432/ai_gateway
# Optional: load model prices from a hosted JSON you control (else the built-in
# table in app/config.py is used). Refreshed on the interval below, with the
# static table as fallback if a fetch fails.
PRICING_SOURCE_URL=
PRICING_REFRESH_SECONDS=3600
